{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "krateo-restaction-agent values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "namespace": { "type": "string" },
    "modelConfig": {
      "type": "string",
      "description": "Name of the kagent ModelConfig the agent uses (shipped by the autopilot)."
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "language": { "type": "string" } }
    },
    "vertexAI": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "projectID": { "type": "string" },
        "location": { "type": "string" }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "description": "github MCP server the agent uses to read its component's codebase + chart.",
      "properties": {
        "enabled": { "type": "boolean" },
        "mcpServer": { "type": "string" }
      }
    },
    "resources": { "type": "object", "additionalProperties": true },
    "global": { "type": "object", "additionalProperties": true }
  }
}
